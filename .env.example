# 复制这个文件为 .env，并填入你自己的 Anthropic API Key
# 获取地址：https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# 可选：识图用的模型，默认是 claude-haiku-4-5-20251001（便宜快）
# CLAUDE_MODEL=claude-haiku-4-5-20251001

# 部署到公网（比如 Fly.io）时必须设置，否则任何人都能访问你的数据
# 本地跑着玩可以不设置
APP_PASSWORD=

# 部署到公网时必须设置成一个固定的随机字符串（用于登录状态签名）
# 生成方法：python3 -c "import secrets; print(secrets.token_hex(32))"
# 本地跑着玩可以不设置，不设置的话每次重启都会随机生成一个（意味着重启后要重新登录）
SECRET_KEY=
